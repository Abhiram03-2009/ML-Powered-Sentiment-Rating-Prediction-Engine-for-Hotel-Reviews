def main():
    parser = argparse.ArgumentParser(
        description="TSA DS&A 2026 — hotel review sentiment ML pipeline"
    )
    parser.add_argument("--demo",    action="store_true", help="Use synthetic demo data")
    parser.add_argument("--no-figs", action="store_true", help="Skip figure generation")
    parser.add_argument("--fig-dir", default="figs",      help="Figure output folder (default: figs/)")
    args = parser.parse_args()

    print("=" * 68)
    print("  TSA DS&A — PA State Conference 2026")
    print("  Decoding Tourist Satisfaction — Sentiment ML Pipeline")
    print("=" * 68)

    df = load_data(demo=args.demo)

    X_tr, X_te, y_tr, y_te = train_test_split(
        df["Review"], df["Sentiment_bin"],
        test_size=0.20, random_state=42, stratify=df["Sentiment_bin"]
    )
    print(f"\nTrain: {len(X_tr):,}  |  Test: {len(X_te):,}")
    print(f"Naive majority-class baseline: {y_tr.mean()*100:.1f}%")

    print("\nTraining 5 classifiers ...")
    pipelines = build_pipelines()
    results   = train_and_evaluate(pipelines, X_tr, X_te, y_tr, y_te)

    lc_data = compute_learning_curves(X_tr, X_te, y_tr, y_te)

    metrics_out = {k: {m: v for m, v in r.items() if m != "cm"} for k, r in results.items()}
    with open("metrics.json", "w") as f:
        json.dump(metrics_out, f, indent=2)
    with open("learning_curves.json", "w") as f:
        json.dump(lc_data, f, indent=2)
    print("\nSaved: metrics.json, learning_curves.json")

    best_name = max(results, key=lambda n: results[n]["accuracy"])
    y_pred    = pipelines[best_name].predict(X_te)
    print(f"\nBest model: {best_name} ({results[best_name]['accuracy']*100:.4f}%)")
    print(classification_report(y_te, y_pred, target_names=["Neg/Neutral", "Positive"]))

    if not args.no_figs:
        generate_figures(df, results, lc_data, pipelines, fig_dir=args.fig_dir)

    print("=" * 68)
    print(f"  Best model : {best_name}")
    print(f"  Accuracy   : {results[best_name]['accuracy']*100:.4f}%")
    print(f"  F1-Score   : {results[best_name]['f1']*100:.4f}%")
    print("=" * 68)


if __name__ == "__main__":
    main()
