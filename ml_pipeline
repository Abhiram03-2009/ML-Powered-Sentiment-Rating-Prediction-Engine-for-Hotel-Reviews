def build_pipelines():
    # Each model is a Pipeline so TF-IDF is always fit on training data only.
    # Wrapping classifier + vectorizer together prevents any data leakage.

    tfidf_full = dict(max_features=8_000, ngram_range=(1, 2), sublinear_tf=True)
    tfidf_lite = dict(max_features=5_000, ngram_range=(1, 1), sublinear_tf=True)

    return {
        "Logistic Regression": Pipeline([
            ("tfidf", TfidfVectorizer(**tfidf_full)),
            ("clf",   LogisticRegression(C=2.0, max_iter=1_000, random_state=42)),
        ]),
        "Naive Bayes": Pipeline([
            ("tfidf", TfidfVectorizer(**tfidf_full)),
            ("clf",   MultinomialNB(alpha=0.5)),
        ]),
        "Linear SVM": Pipeline([
            ("tfidf", TfidfVectorizer(**tfidf_full)),
            ("clf",   LinearSVC(C=1.0, max_iter=3_000, random_state=42)),
        ]),
        "Random Forest": Pipeline([
            ("tfidf", TfidfVectorizer(**tfidf_lite)),
            ("clf",   RandomForestClassifier(n_estimators=200, random_state=42, n_jobs=-1)),
        ]),
        "Gradient Boosting": Pipeline([
            ("tfidf", TfidfVectorizer(**tfidf_lite)),
            ("clf",   GradientBoostingClassifier(n_estimators=150, max_depth=4, random_state=42)),
        ]),
    }


