def make_review(rating):
    n = np.random.randint(14, 50)
    if rating >= 4:
        pw, nw = int(n * 0.60), int(n * 0.05)
    elif rating == 3:
        pw, nw = int(n * 0.25), int(n * 0.25)
    else:
        pw, nw = int(n * 0.05), int(n * 0.60)
    nuw = max(0, n - pw - nw)
    words = (
        list(np.random.choice(POS_WORDS, pw, replace=True))
        + list(np.random.choice(NEG_WORDS, nw, replace=True))
        + list(np.random.choice(NEU_WORDS, nuw, replace=True))
    )
    np.random.shuffle(words)
    return " ".join(words)


def load_data(demo=False):
    CSV = "tripadvisor_hotel_reviews.csv"

    if not demo and os.path.exists(CSV):
        print(f"Loading real dataset from '{CSV}' ...")
        df = pd.read_csv(CSV)
        df.columns = [c.strip() for c in df.columns]
        # handle both capitalisation variants from Kaggle
        for old, new in [("review", "Review"), ("rating", "Rating")]:
            if old in df.columns and new not in df.columns:
                df.rename(columns={old: new}, inplace=True)
        df = df[["Review", "Rating"]].dropna()
        df["Rating"] = df["Rating"].astype(int)
    else:
        if not demo:
            print(f"'{CSV}' not found — falling back to demo data.")
            print("Download: kaggle.com/datasets/andrewmvd/trip-advisor-hotel-reviews")
        else:
            print("Demo mode: generating synthetic dataset (n=20,491) ...")

        N = 20_491
        dist = {5: 0.497, 4: 0.239, 3: 0.113, 2: 0.085, 1: 0.066}
        ratings = np.random.choice([1, 2, 3, 4, 5], size=N, p=list(dist.values()))
        df = pd.DataFrame({"Review": [make_review(r) for r in ratings], "Rating": ratings})

    df["Word_count"]    = df["Review"].apply(lambda x: len(str(x).split()))
    df["Sentiment_bin"] = (df["Rating"] >= 4).astype(int)

    pos_pct = df["Sentiment_bin"].mean() * 100
    print(f"Loaded {len(df):,} reviews — Positive: {pos_pct:.1f}%  Neg/Neu: {100-pos_pct:.1f}%")
    return df


