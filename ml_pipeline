def compute_learning_curves(X_tr, X_te, y_tr, y_te):
    print("Computing learning curves ...")

    lc_models = {
        "LR":  (LogisticRegression(C=2, max_iter=500, random_state=42),  CYAN),
        "SVM": (LinearSVC(C=1, max_iter=2_000, random_state=42),         PURP),
        "NB":  (MultinomialNB(alpha=0.5),                                AMB),
        "RF":  (RandomForestClassifier(n_estimators=100, random_state=42), GRN),
    }

    fracs  = np.linspace(0.10, 1.0, 10)
    output = {}

    for mname, (clf, _) in lc_models.items():
        tr_acc, te_acc = [], []
        for f in fracs:
            n  = int(f * len(X_tr))
            Xt = X_tr.iloc[:n]
            yt = y_tr.iloc[:n]
            pipe = Pipeline([
                ("t", TfidfVectorizer(max_features=5_000, sublinear_tf=True)),
                ("c", clf),
            ])
            pipe.fit(Xt, yt)
            tr_acc.append(float(accuracy_score(yt,  pipe.predict(Xt))))
            te_acc.append(float(accuracy_score(y_te, pipe.predict(X_te))))

        output[mname] = {
            "train": tr_acc,
            "test":  te_acc,
            "sizes": [int(f * len(X_tr)) for f in fracs],
        }
        print(f"  {mname}: test acc at full training = {te_acc[-1]*100:.2f}%")

    return output


