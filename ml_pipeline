def train_and_evaluate(pipelines, X_tr, X_te, y_tr, y_te):
    results  = {}
    baseline = y_tr.mean()

    print(f"\n{'─'*68}")
    print(f"  {'Model':<24}  {'Acc':>7}  {'F1':>7}  {'Prec':>7}  {'Rec':>7}  {'Δ Base':>8}")
    print(f"{'─'*68}")

    for name, pipe in pipelines.items():
        pipe.fit(X_tr, y_tr)
        yp = pipe.predict(X_te)

        acc  = accuracy_score(y_te, yp)
        f1   = f1_score(y_te, yp,  average="weighted")
        prec = precision_score(y_te, yp, average="weighted")
        rec  = recall_score(y_te, yp,  average="weighted")

        results[name] = {
            "accuracy":  round(acc,  4),
            "f1":        round(f1,   4),
            "precision": round(prec, 4),
            "recall":    round(rec,  4),
            "cm":        confusion_matrix(y_te, yp).tolist(),
        }

        best_so_far = acc == max(r["accuracy"] for r in results.values())
        mark = " ★" if best_so_far else "  "
        delta = (acc - baseline) * 100
        print(f"  {name:<24}{mark} {acc*100:>6.2f}%  {f1*100:>6.2f}%"
              f"  {prec*100:>6.2f}%  {rec*100:>6.2f}%  +{delta:>6.2f}pp")

    print(f"{'─'*68}")
    print(f"  {'Naive Baseline':<26} {baseline*100:>6.2f}%    —       —       —"
          f"    (majority class)\n")
    return results


